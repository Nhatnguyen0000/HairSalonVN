@using HairSalonVN.Web.Models.Admin
@using HairSalonVN.Web.Models.Booking
@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
    ViewBag.DashboardRole = "Admin";
    ViewBag.ActiveMenu = "dashboard";
    ViewBag.PendingCount = Model.PendingCount;

    var today = DateTime.Now;
}
<div class="luxe-topbar">
    <div class="luxe-topbar-left">
        <h1>Tổng quan</h1>
        <p class="luxe-date">
            @today.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"))
        </p>
    </div>
    <div class="luxe-topbar-right">
        <a href="/Admin/Appointments" class="luxe-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Quản lý lịch hẹn
        </a>
    </div>
</div>

<div class="luxe-content">
    <div class="luxe-stats">
        <div class="stat-card stat-card-primary">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.TotalAppointmentsToday</span>
                <span class="stat-text">Lịch hẹn hôm nay</span>
            </div>
        </div>
        <div class="stat-card stat-card-warning">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12,6 12,12 16,14"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.PendingCount</span>
                <span class="stat-text">Chờ xác nhận</span>
            </div>
        </div>
        <div class="stat-card stat-card-success">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22,4 12,14.01 9,11.01"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.CompletedCount</span>
                <span class="stat-text">Hoàn thành tháng</span>
            </div>
        </div>
        <div class="stat-card stat-card-gold">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.RevenueDisplay</span>
                <span class="stat-text">Doanh thu tháng</span>
            </div>
        </div>
    </div>

    <div class="luxe-panel">
        <div class="luxe-panel-head">
            <h2>Lịch hẹn gần đây</h2>
            <a href="/Admin/Appointments" class="luxe-link">Xem tất cả →</a>
        </div>
        <div class="luxe-panel-body">
            @if (!Model.RecentAppointments.Any())
            {
                <div class="luxe-empty">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <p>Chưa có lịch hẹn nào</p>
                    <small>Không có dữ liệu trong hệ thống</small>
                </div>
            }
            else
            {
                <div class="luxe-table-wrap">
                    <table class="luxe-table">
                        <thead>
                            <tr>
                                <th>Mã đặt</th>
                                <th>Khách hàng</th>
                                <th>Dịch vụ</th>
                                <th>Stylist</th>
                                <th>Thời gian</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in Model.RecentAppointments)
                            {
                                <tr>
                                    <td><span class="luxe-code">@appt.BookingCode</span></td>
                                    <td>
                                        <div class="luxe-person">
                                            <div class="luxe-avatar">@(string.IsNullOrEmpty(appt.CustomerName) ? '?' : appt.CustomerName[0])</div>
                                            <div>
                                                <div class="luxe-person-name">@appt.CustomerName</div>
                                                <div class="luxe-person-sub">@appt.CustomerPhone</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="luxe-person-name">@appt.ServiceName</div>
                                        <div class="luxe-price">@appt.ServicePrice.ToString("N0")đ</div>
                                    </td>
                                    <td>
                                        <div class="luxe-person">
                                            <div class="luxe-avatar">@(string.IsNullOrEmpty(appt.StaffName) ? '?' : appt.StaffName[0])</div>
                                            <div class="luxe-person-name">@appt.StaffName</div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="luxe-date-cell">
                                            <span class="date">@appt.AppointmentDate.ToString("dd/MM/yyyy")</span>
                                            <span class="time">@appt.AppointmentDate.ToString("HH:mm")</span>
                                        </div>
                                    </td>
                                    <td><span class="luxe-badge @appt.StatusClass">@appt.Status</span></td>
                                    <td>
                                        <div class="luxe-actions">
                                        @if (appt.Status == "Pending")
                                        {
                                            <button type="button" class="btn-confirm-sm"
                                                    onclick="confirmAppointment('@appt.Id', 'Confirmed', this)">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                    <polyline points="20,6 9,17 4,12"/>
                                                </svg>
                                                Xác nhận
                                            </button>
                                        }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="luxe-panel">
        <div class="luxe-panel-head">
            <h2>Thao tác nhanh</h2>
        </div>
        <div class="luxe-quick-grid">
            <a href="/Admin/Appointments" class="luxe-quick-card">
                <div class="luxe-quick-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </div>
                <div>
                    <h3>Quản lý lịch hẹn</h3>
                    <p>Xem và cập nhật trạng thái</p>
                </div>
            </a>
            <a href="/Admin/Services" class="luxe-quick-card">
                <div class="luxe-quick-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <div>
                    <h3>Quản lý dịch vụ</h3>
                    <p>Thêm, sửa dịch vụ</p>
                </div>
            </a>
            <a href="/Admin/Staff" class="luxe-quick-card">
                <div class="luxe-quick-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </div>
                <div>
                    <h3>Nhân viên</h3>
                    <p>Phân công lịch làm</p>
                </div>
            </a>
            <a href="/" class="luxe-quick-card">
                <div class="luxe-quick-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9,22 9,12 15,12 15,22"/>
                    </svg>
                </div>
                <div>
                    <h3>Về trang chủ</h3>
                    <p>Trang landing page</p>
                </div>
            </a>
        </div>
    </div>
</div>

<script>
(function() {
    window.confirmAppointment = function(id, status, btn) {
        if (!btn) return;
        var originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/></svg> Đang xử lý...';
        fetch('/Admin/UpdateAppointmentStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + id + '&status=' + status + '&__RequestVerificationToken=' + document.querySelector('input[name="__RequestVerificationToken"]').value
        })
        .then(function(r) { return r.json(); })
        .then(function(resp) {
            if (resp.success) {
                showToast(resp.message || 'Cập nhật thành công!', 'success');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                showToast(resp.message || 'Có lỗi xảy ra', 'error');
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        })
        .catch(function() {
            showToast('Không thể kết nối máy chủ', 'error');
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
    };
})();
</script>
