@using HairSalonVN.Web.Models.Auth
@model RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng ký – LUXE Hair Salon</title>
    <link rel="stylesheet" href="~/css/salon.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-card scale-in">
            <div class="auth-header">
                <div class="auth-logo">
                    LUXE<span class="gold">Hair</span>
                </div>
                <p class="auth-sub">Tạo tài khoản mới để đặt lịch ngay</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="salon-alert salon-alert-error">
                    @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                </div>
            }

            <form asp-action="Register" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FullName" class="salon-label">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            Họ và tên
                        </label>
                        <input asp-for="FullName"
                               class="salon-form-control"
                               placeholder="Nguyen Van A"
                               autocomplete="name" />
                        <span asp-validation-for="FullName" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="salon-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        Email
                    </label>
                    <input asp-for="Email"
                           class="salon-form-control @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "is-invalid" : "")"
                           placeholder="email@cuaban.com"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="salon-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                        </svg>
                        Số điện thoại
                    </label>
                    <input asp-for="Phone"
                           class="salon-form-control"
                           placeholder="0901234567"
                           autocomplete="tel" />
                    <span asp-validation-for="Phone" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="salon-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        Mật khẩu
                    </label>
                    <input asp-for="Password" type="password"
                           class="salon-form-control"
                           placeholder="Tối thiểu 6 ký tự"
                           autocomplete="new-password" />
                    <span asp-validation-for="Password" class="invalid-feedback"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="salon-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <polyline points="22,4 12,14.01 9,11.01"/>
                        </svg>
                        Xác nhận mật khẩu
                    </label>
                    <input asp-for="ConfirmPassword" type="password"
                           class="salon-form-control"
                           placeholder="Nhập lại mật khẩu"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="invalid-feedback"></span>
                </div>

                <div class="form-terms">
                    <label class="checkbox-label">
                        <input type="checkbox" required />
                        <span>Tôi đồng ý với <a href="#">Điều khoản sử dụng</a> và <a href="#">Chính sách bảo mật</a></span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="8.5" cy="7" r="4"/>
                        <line x1="20" y1="8" x2="20" y2="14"/>
                        <line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                    Tạo tài khoản
                </button>
            </form>

            <div class="auth-divider">hoặc</div>

            <div class="auth-footer">
                <p class="auth-link">
                    Đã có tài khoản?
                    <a href="/Account/Login">Đăng nhập ngay</a>
                </p>
            </div>

            <div class="auth-back">
                <a href="/" class="btn btn-ghost btn-sm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12,19 5,12 12,5"/>
                    </svg>
                    Quay về trang chủ
                </a>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
