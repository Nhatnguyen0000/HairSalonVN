@using HairSalonVN.Web.Models.Booking
@model IEnumerable<StaffSlotViewModel>
@{
    ViewData["Title"] = "Chọn stylist và giờ";
    ViewData["BodyClass"] = "page-booking";

    var serviceId    = ViewBag.ServiceId;
    var serviceName  = ViewBag.ServiceName ?? "";
    var servicePrice = ViewBag.ServicePrice ?? 0m;
    var duration     = ViewBag.Duration ?? 0;
    var selectedDate = ViewBag.Date ?? DateTime.Today.ToString("yyyy-MM-dd");
    var staffList   = Model?.ToList() ?? new List<StaffSlotViewModel>();
    var hasStaff    = staffList.Count > 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
}

<!-- Hero Header -->
<div class="slot-hero">
    <div class="slot-hero-bg">
        <div class="slot-blob"></div>
        <div class="slot-blob"></div>
    </div>
    <div class="container">
        <div class="slot-hero-content">
            <a href="/Booking" class="back-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"/>
                    <polyline points="12,19 5,12 12,5"/>
                </svg>
                <span>Quay lại</span>
            </a>
            <h1>Chọn stylist và giờ</h1>
            <div class="service-summary">
                <span class="service-name">@serviceName</span>
                <span class="separator">·</span>
                <span class="service-price">@servicePrice.ToString("N0")đ</span>
                <span class="separator">·</span>
                <span class="service-duration">@duration phút</span>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="slot-container">
    <div class="container">

        <!-- Date Picker -->
        <div class="date-picker-section">
            <div class="date-picker-header">
                <h2>Chọn ngày</h2>
            </div>
            <div class="date-scroll-container">
                <div class="date-grid" id="dateGrid"></div>
            </div>
            <input type="hidden" id="selectedDate" value="@selectedDate" />
        </div>

        <div class="slot-main-grid">
            <!-- Stylist Selection -->
            <div class="stylist-section">
                <h2>Chọn stylist</h2>
                <div class="stylist-list" id="stylistList">
                    @if (hasStaff)
                    {
                        @foreach (var s in staffList)
                        {
                            var sid       = s.StaffId != Guid.Empty ? s.StaffId : s.Id;
                            var name      = string.IsNullOrEmpty(s.StaffName) ? "Stylist" : s.StaffName;
                            var specialty = string.IsNullOrEmpty(s.Specialty) ? "Stylist" : s.Specialty;
                            var initial   = name.Length > 0 ? name[0].ToString().ToUpper() : "?";
                            var isAvail   = s.IsAvailable;
                            <div class="stylist-card" data-staff-id="@sid" data-staff-name="@name">
                                <div class="stylist-avatar">
                                    @if (!string.IsNullOrEmpty(s.AvatarUrl))
                                    {
                                        <img src="@s.AvatarUrl" alt="@name" />
                                    }
                                    else
                                    {
                                        <div class="avatar-placeholder">@initial</div>
                                    }
                                </div>
                                <div class="stylist-info">
                                    <h4>@name</h4>
                                    <p class="specialty">@specialty</p>
                                    <div class="stylist-status">
                                        <span class="status-dot @(isAvail ? "available" : "")"></span>
                                        <span>@(isAvail ? "Sẵn sàng" : "Bận")</span>
                                    </div>
                                </div>
                                <div class="select-indicator">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20,6 9,17 4,12"/>
                                    </svg>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="stylist-empty">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                                <path d="M16 3.13a4 4 0 010 7.75"/>
                            </svg>
                            <p>Không có stylist nào cho dịch vụ này</p>
                            <small>Vui lòng chọn dịch vụ khác</small>
                        </div>
                    }
                </div>
                <input type="hidden" id="selectedStaffId" />
            </div>

            <!-- Time Slots -->
            <div class="timeslot-section">
                <h2>Chọn giờ</h2>
                <div class="timeslot-content" id="timeslotContent">
                    <div class="timeslot-placeholder">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12,6 12,12 16,14"/>
                        </svg>
                        <p>Vui lòng chọn ngày và stylist</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Booking Summary (Sticky) -->
        <div class="booking-summary-bar is-hidden" id="bookingSummary">
            <div class="summary-info">
                <div class="summary-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <span id="summaryDate">--</span>
                </div>
                <div class="summary-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12,6 12,12 16,14"/>
                    </svg>
                    <span id="summaryTime">--</span>
                </div>
                <div class="summary-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    <span id="summaryStylist">--</span>
                </div>
            </div>
            <button type="button" id="confirmBtn" class="btn-confirm-booking">
                <span>Xác nhận đặt lịch</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12,5 19,12 12,19"/>
                </svg>
            </button>
        </div>
    </div>
</div>

<form id="bookingForm" action="/Booking/Confirm" method="get" class="is-hidden">
    <input type="hidden" name="serviceId"  value="@serviceId" />
    <input type="hidden" name="staffId"   id="formStaffId" />
    <input type="hidden" name="date"      id="formDate" />
    <input type="hidden" name="time"      id="formTime" />
</form>

<script>
(function() {
    var dateGrid          = document.getElementById('dateGrid');
    var selectedDateInput = document.getElementById('selectedDate');
    var selectedStaffIdInput = document.getElementById('selectedStaffId');
    var stylistList       = document.getElementById('stylistList');
    var timeslotContent  = document.getElementById('timeslotContent');
    var bookingSummary    = document.getElementById('bookingSummary');
    var confirmBtn        = document.getElementById('confirmBtn');
    var bookingForm       = document.getElementById('bookingForm');
        var selectedDateValue = selectedDateInput.value || '@selectedDate' || DateTime.Today.toISOString().split('T')[0];
    var serviceId         = '@serviceId';

    var selectedStylistId = null;
    var selectedTime      = null;
    var dayNames   = ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'];
    var monthNames = ['Thg 1', 'Thg 2', 'Thg 3', 'Thg 4', 'Thg 5', 'Thg 6',
                      'Thg 7', 'Thg 8', 'Thg 9', 'Thg 10', 'Thg 11', 'Thg 12'];

    // ── 1. Date picker ───────────────────────────────────────────────
     function initDatePicker() {
        dateGrid.innerHTML = '';
        var dateToSelect = selectedDateInput.value || '@selectedDate'; // Dùng giá trị từ input trước
        var startDate = new Date(dateToSelect);
        startDate.setDate(startDate.getDate() - startDate.getDay());
        var today = new Date();
        today.setHours(0, 0, 0, 0);
        var selectedMidnight = new Date(dateToSelect);
        selectedMidnight.setHours(0, 0, 0, 0);

        for (var i = 0; i < 14; i++) {
            var d = new Date(startDate);
            d.setDate(startDate.getDate() + i);
            if (d < today) continue;

            var isSelected = d.toDateString() === selectedMidnight.toDateString();
            var card = document.createElement('div');
            card.className = 'date-card' + (isSelected ? ' selected' : '');
            card.innerHTML =
                '<span class="day-name">'   + dayNames[d.getDay()]   + '</span>' +
                '<span class="day-number">' + d.getDate()           + '</span>' +
                '<span class="month-name">' + monthNames[d.getMonth()] + '</span>';
            card.dataset.date = d.toISOString().split('T')[0];
            card.addEventListener('click', function() { selectDate(this); });
            dateGrid.appendChild(card);
        }
     }
    initDatePicker();

    function selectDate(card) {
        dateGrid.querySelectorAll('.date-card').forEach(function(c) {
            c.classList.remove('selected');
        });
        card.classList.add('selected');
        selectedDateInput.value = card.dataset.date;
        selectedTime = null;

        // Reload time slots if stylist is already selected
        if (selectedStylistId) {
            loadTimeSlots();
        }
        updateSummary();
    }

    // ── 2. Stylist selection ─────────────────────────────────────────
    function selectStylist(card) {
        stylistList.querySelectorAll('.stylist-card').forEach(function(c) {
            c.classList.remove('selected');
        });
        card.classList.add('selected');
        selectedStylistId = card.dataset.staffId;
        selectedStaffIdInput.value = selectedStylistId;
        selectedTime = null;
        loadTimeSlots();
        updateSummary();
    }

    stylistList.querySelectorAll('.stylist-card').forEach(function(card) {
        card.addEventListener('click', function() { selectStylist(card); });
    });

    // Auto-select if only one stylist
    var cards = stylistList.querySelectorAll('.stylist-card');
    if (cards.length === 1) {
        selectStylist(cards[0]);
    }

    // ── 3. Time slots ───────────────────────────────────────────────
    function loadTimeSlots() {
        if (!selectedStylistId || !selectedDateInput.value) {
            console.log('Skipping loadTimeSlots: missing staffId or date');
            return;
        }

        timeslotContent.innerHTML =
            '<div class="timeslot-loading"><div class="timeslot-loading-spinner"></div><p>Đang tải khung giờ...</p></div>';

        // Đảm bảo date format đúng yyyy-MM-dd
        var dateValue = selectedDateInput.value;
        var url = '/Booking/GetSlots?staffId=' + selectedStylistId +
                  '&serviceId=' + serviceId +
                  '&date=' + encodeURIComponent(dateValue);

        console.log('Loading slots from:', url);
        console.log('Date value:', dateValue);

        fetch(url)
            .then(function(r) {
                console.log('Response status:', r.status);
                return r.json();
            })
            .then(function(resp) {
                console.log('API Response:', resp);
                var slots = resp && resp.data ? resp.data : [];
                if (slots.length === 0 && resp && resp.errors) {
                    console.log('API Errors:', resp.errors);
                }
                renderTimeSlots(slots);
            })
            .catch(function(err) {
                console.error('Fetch error:', err);
                timeslotContent.innerHTML =
                    '<div class="timeslot-placeholder"><p>Lỗi tải khung giờ. Vui lòng thử lại.</p><small>' + err.message + '</small></div>';
            });
    }

    function renderTimeSlots(slots) {
        console.log('Rendering slots:', slots);
        if (!slots || slots.length === 0) {
            timeslotContent.innerHTML =
                '<div class="timeslot-placeholder"><p>Không có khung giờ trống cho ngày này</p></div>';
            return;
        }

        var grid = document.createElement('div');
        grid.className = 'timeslot-grid';

        slots.forEach(function(slot) {
            var label  = slot.label || slot.Label || slot.time || slot.Time || '??:??';
            var isAvail = slot.isAvail !== false && slot.IsAvail !== false && slot.isAvailable !== false;
            console.log('Slot:', label, 'Available:', isAvail);
            var el = document.createElement('div');
            el.className = 'timeslot-slot' + (isAvail ? '' : ' disabled');
            el.textContent = label;
            if (isAvail) {
                el.addEventListener('click', function() { selectTime(el, label); });
            }
            grid.appendChild(el);
        });

        timeslotContent.innerHTML = '';
        timeslotContent.appendChild(grid);
    }

    function selectTime(el, label) {
        timeslotContent.querySelectorAll('.timeslot-slot').forEach(function(s) {
            s.classList.remove('selected');
        });
        el.classList.add('selected');
        selectedTime = label;
        console.log('Selected time:', label);
        updateSummary();
    }

    // ── 4. Booking summary ───────────────────────────────────────────
    function updateSummary() {
        if (!selectedDateInput.value || !selectedStylistId || !selectedTime) {
            bookingSummary.classList.add('is-hidden');
            return;
        }

        bookingSummary.classList.remove('is-hidden');

        var d = new Date(selectedDateInput.value + 'T00:00:00');
        var vnDays = ['Chủ nhật', 'Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7'];
        document.getElementById('summaryDate').textContent =
            vnDays[d.getDay()] + ', ' + d.getDate() + '/' + (d.getMonth() + 1);
        document.getElementById('summaryTime').textContent = selectedTime;

        var sc = stylistList.querySelector('.stylist-card[data-staff-id="' + selectedStylistId + '"]');
        document.getElementById('summaryStylist').textContent =
            sc ? sc.dataset.staffName : 'Stylist';
    }

    // ── 5. Confirm button ───────────────────────────────────────────
    confirmBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (!selectedStylistId || !selectedDateInput.value || !selectedTime) {
            alert('Vui lòng chọn ngày, stylist và khung giờ.');
            return;
        }
        document.getElementById('formStaffId').value = selectedStylistId;
        document.getElementById('formDate').value    = selectedDateInput.value;
        document.getElementById('formTime').value    = selectedTime;
        bookingForm.submit();
    });

    // ── Init ────────────────────────────────────────────────────────
    // Sync selectedDateValue with input value (handles timezone issues)
    selectedDateValue = selectedDateInput.value || selectedDateValue;
    initDatePicker();
})();
</script>
