@using HairSalonVN.Web.Models.Booking
@model MyBookingsViewModel
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Lịch của tôi";
    ViewBag.DashboardRole = "Customer";
    ViewBag.ActiveMenu = "mybookings";

    var appointments = Model.Appointments?.ToList() ?? new List<AppointmentViewModel>();
    var totalCount = Model.TotalCount;
    var pendingCount = Model.PendingCount;
    var confirmedCount = Model.ConfirmedCount;
    var completedCount = Model.CompletedCount;
}

<!-- Topbar -->
<div class="luxe-topbar">
    <div class="luxe-topbar-left">
        <h1>Lịch hẹn của tôi</h1>
        <p class="luxe-date">Theo dõi và quản lý các lịch hẹn</p>
    </div>
    <div class="luxe-topbar-right">
        <a href="/Booking" class="luxe-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Đặt lịch mới
        </a>
    </div>
</div>

<!-- Content -->
<div class="luxe-content">

    <!-- Stats -->
    <div class="luxe-stats">
        <div class="stat-card stat-card-primary">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@totalCount</span>
                <span class="stat-text">Tổng lịch hẹn</span>
            </div>
        </div>
        <div class="stat-card stat-card-warning">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12,6 12,12 16,14"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@pendingCount</span>
                <span class="stat-text">Đang chờ</span>
            </div>
        </div>
        <div class="stat-card stat-card-success">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22,4 12,14.01 9,11.01"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@confirmedCount</span>
                <span class="stat-text">Đã xác nhận</span>
            </div>
        </div>
        <div class="stat-card stat-card-gold">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23,6 13.5,15.5 8.5,10.5 1,18"/>
                    <polyline points="17,6 23,6 23,12"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@completedCount</span>
                <span class="stat-text">Hoàn thành</span>
            </div>
        </div>
    </div>

    <!-- Bookings List -->
    <div class="luxe-panel">
        <div class="luxe-panel-head">
            <h2>Danh sách lịch hẹn</h2>
            @if (totalCount > 0)
            {
                <span class="luxe-badge pending">@totalCount lịch</span>
            }
        </div>
        <div class="luxe-panel-body">
            @if (!appointments.Any())
            {
                <div class="luxe-empty">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <p>Chưa có lịch hẹn nào</p>
                    <small>Bắt đầu đặt lịch ngay để trải nghiệm dịch vụ của chúng tôi</small>
                </div>
            }
            else
            {
                <div class="mybooking-list">
                    @foreach (var appt in appointments.OrderByDescending(a => a.AppointmentDate))
                    {
                        <div class="mb-card" data-status="@appt.Status">
                            <div class="mb-service-img">
                                @if (!string.IsNullOrEmpty(appt.ServiceImageUrl))
                                {
                                    <img src="@appt.ServiceImageUrl" alt="@appt.ServiceName"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                }
                                <div class="mb-no-img">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <path d="M6 3L3 6v15a2 2 0 002 2h14a2 2 0 002-2V6l-3-3z"/>
                                        <path d="M3 6h18"/>
                                        <path d="M16 10a4 4 0 01-8 0"/>
                                    </svg>
                                </div>
                            </div>

                            <div class="mb-info">
                                <div class="mb-top">
                                    <div class="mb-name">@appt.ServiceName</div>
                                    <span class="luxe-badge @GetStatusClass(appt.Status)">@GetStatusLabel(appt.Status)</span>
                                </div>
                                <div class="mb-details">
                                    <span>
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"/>
                                            <polyline points="12,6 12,12 16,14"/>
                                        </svg>
                                        @appt.AppointmentDate.ToString("HH:mm") – @appt.AppointmentDate.AddMinutes(appt.DurationMinutes).ToString("HH:mm")
                                    </span>
                                    <span>
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                                            <line x1="3" y1="10" x2="21" y2="10"/>
                                        </svg>
                                        @appt.AppointmentDate.ToString("dd/MM/yyyy")
                                    </span>
                                    <span>
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                            <circle cx="12" cy="7" r="4"/>
                                        </svg>
                                        @appt.StaffName · @appt.DurationMinutes phút
                                    </span>
                                </div>
                                <div class="mb-bottom">
                                    <span class="luxe-code">@appt.BookingCode</span>
                                    <span class="mb-price">@appt.ServicePrice.ToString("N0")đ</span>
                                </div>
                                @if (!string.IsNullOrEmpty(appt.Notes))
                                {
                                    <div class="mb-notes">@appt.Notes</div>
                                }
                            </div>

                            <div class="mb-actions">
                                @if (appt.Status == "Completed" && !appt.HasReview)
                                {
                                    <button type="button" class="luxe-btn-sm review"
                                            onclick="openReviewModal('@appt.Id', '@appt.StaffName', '@appt.ServiceName', '@appt.AppointmentDate.ToString("dd/MM/yyyy")')">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                                        </svg>
                                        Đánh giá
                                    </button>
                                }
                                @if (appt.Status == "Completed" && appt.HasReview)
                                {
                                    <span class="reviewed-badge">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                            <polyline points="20,6 9,17 4,12"/>
                                        </svg>
                                        Đã đánh giá
                                    </span>
                                }
                                @if (appt.Status == "Pending" || appt.Status == "Confirmed")
                                {
                                    <form asp-controller="Booking" asp-action="Cancel" method="post"
                                          class="cancel-form" data-appt-id="@appt.Id">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        <button type="submit" class="luxe-btn-sm cancel">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <line x1="18" y1="6" x2="6" y2="18"/>
                                                <line x1="6" y1="6" x2="18" y2="18"/>
                                            </svg>
                                            Hủy lịch
                                        </button>
                                    </form>
                                }
                                @if (appt.Status == "Cancelled" || appt.Status == "Completed")
                                {
                                    <a href="/Booking/SelectSlot?serviceId=@appt.ServiceId&date=@DateTime.Today.ToString("yyyy-MM-dd")"
                                       class="luxe-btn-sm confirm">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <polyline points="23,4 23,10 17,10"/>
                                            <path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
                                        </svg>
                                        Đặt lại
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="review-modal" id="reviewModal">
    <div class="modal-overlay" onclick="closeReviewModal()"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h3>Đánh giá dịch vụ</h3>
            <button class="modal-close" onclick="closeReviewModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <div class="modal-review-info">
            <div class="review-info-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 3L3 6v15a2 2 0 002 2h14a2 2 0 002-2V6l-3-3z"/>
                    <path d="M3 6h18"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                <span id="reviewServiceName">-</span>
            </div>
            <div class="review-info-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span id="reviewStaffName">-</span>
            </div>
            <div class="review-info-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <span id="reviewDate">-</span>
            </div>
        </div>
        <form id="reviewForm" onsubmit="submitReview(event)">
            <input type="hidden" id="reviewAppointmentId" value="" />
            <div class="rating-section">
                <span>Chất lượng dịch vụ</span>
                <div class="star-rating" id="starRating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <button type="button" class="star" data-rating="@i" onclick="setRating(@i)">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                            </svg>
                        </button>
                    }
                </div>
                <div class="rating-label" id="ratingLabel"></div>
                <input type="hidden" id="reviewRating" value="0" />
            </div>
            <div class="comment-section">
                <label for="reviewComment">Nhận xét của bạn</label>
                <textarea id="reviewComment" rows="4"
                          placeholder="Chia sẻ trải nghiệm của bạn với dịch vụ và stylist..."></textarea>
            </div>
            <button type="submit" class="btn-submit-review" id="submitReviewBtn">
                <span>Gửi đánh giá</span>
                <div class="spinner-sm" style="display:none;"></div>
            </button>
        </form>
    </div>
</div>

<script>
(function() {
    const ratingTexts = ['', 'Rất kém', 'Kém', 'Bình thường', 'Tốt', 'Xuất sắc'];

    window.openReviewModal = function(apptId, staffName, serviceName, date) {
        document.getElementById('reviewAppointmentId').value = apptId;
        document.getElementById('reviewStaffName').textContent = staffName || '-';
        document.getElementById('reviewServiceName').textContent = serviceName || '-';
        document.getElementById('reviewDate').textContent = date || '-';
        document.getElementById('reviewRating').value = 0;
        document.getElementById('ratingLabel').textContent = '';
        document.getElementById('reviewComment').value = '';
        document.querySelectorAll('.star').forEach(function(s) { s.classList.remove('active'); });
        document.getElementById('reviewModal').classList.add('active');
        document.body.style.overflow = 'hidden';
    };

    window.closeReviewModal = function() {
        document.getElementById('reviewModal').classList.remove('active');
        document.body.style.overflow = '';
    };

    window.setRating = function(rating) {
        document.getElementById('reviewRating').value = rating;
        document.getElementById('ratingLabel').textContent = ratingTexts[rating] || '';
        document.querySelectorAll('.star').forEach(function(s, i) {
            if (i < rating) s.classList.add('active');
            else s.classList.remove('active');
        });
    };

    window.submitReview = function(e) {
        e.preventDefault();
        var rating = parseInt(document.getElementById('reviewRating').value);
        var appointmentId = document.getElementById('reviewAppointmentId').value;
        var comment = document.getElementById('reviewComment').value;
        var btn = document.getElementById('submitReviewBtn');

        if (rating < 1 || rating > 5) {
            showToast('Vui lòng chọn số sao đánh giá', 'warning');
            return;
        }

        btn.disabled = true;
        btn.querySelector('span').textContent = 'Đang gửi...';
        btn.querySelector('.spinner-sm').style.display = 'block';

        var data = {
            appointmentId: appointmentId,
            rating: rating,
            comment: comment
        };

        fetch('/Booking/SubmitReview', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify(data)
        })
        .then(function(r) { return r.json(); })
        .then(function(resp) {
            if (resp.success) {
                showToast('Cảm ơn bạn đã đánh giá!', 'success');
                closeReviewModal();
                setTimeout(function() { location.reload(); }, 800);
            } else {
                showToast(resp.message || 'Có lỗi xảy ra', 'error');
                btn.disabled = false;
                btn.querySelector('span').textContent = 'Gửi đánh giá';
                btn.querySelector('.spinner-sm').style.display = 'none';
            }
        })
        .catch(function() {
            showToast('Không thể kết nối máy chủ', 'error');
            btn.disabled = false;
            btn.querySelector('span').textContent = 'Gửi đánh giá';
            btn.querySelector('.spinner-sm').style.display = 'none';
        });
    };

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeReviewModal();
    });

    document.querySelectorAll('.cancel-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var apptId = this.dataset.apptId;
            showConfirmModal('Bạn có chắc muốn hủy lịch hẹn này?', function() {
                var formData = new FormData(form);
                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(function(r) {
                    if (r.ok) {
                        showToast('Đã hủy lịch hẹn!', 'success');
                        setTimeout(function() { location.reload(); }, 800);
                    } else {
                        showToast('Không thể hủy lịch hẹn', 'error');
                    }
                })
                .catch(function() {
                    showToast('Không thể kết nối máy chủ', 'error');
                });
            });
        });
    });
})();
</script>

@functions {
    static string GetStatusLabel(string status) => status switch
    {
        "Pending" => "Chờ xác nhận",
        "Confirmed" => "Đã xác nhận",
        "Completed" => "Hoàn thành",
        "Cancelled" => "Đã hủy",
        _ => status
    };

    static string GetStatusClass(string status) => status switch
    {
        "Pending" => "pending",
        "Confirmed" => "confirmed",
        "Completed" => "completed",
        "Cancelled" => "cancelled",
        _ => ""
    };
}
