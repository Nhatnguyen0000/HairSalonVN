@{
    var role = ViewBag.DashboardRole as string ?? "Admin";
    var active = ViewBag.ActiveMenu as string ?? "";
    var pending = ViewBag.PendingCount as int? ?? 0;
    var userName = Context.Session.GetString("UserName") ?? "";
    var userInitial = string.IsNullOrEmpty(userName) ? "?" : userName[0].ToString().ToUpper();
}

<aside class="dash-sidebar">

    <!-- Brand -->
    <div class="dash-brand">
        <a href="/" class="brand-link">
            <span class="dash-brand-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 3L3 6v15a2 2 0 002 2h14a2 2 0 002-2V6l-3-3z"/>
                    <path d="M3 6h18"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
            </span>
            <span class="dash-brand-text">
                <span class="name">LUXE Hair</span>
                <span class="sub">Premium Salon</span>
            </span>
        </a>
    </div>

    <!-- User Info -->
    <div class="dash-user">
        <div class="user-avatar">@userInitial</div>
        <div class="user-info">
            <span class="user-name">@userName</span>
            <span class="user-role">
                @if (role == "Admin")
                {
                    <span class="role-badge admin">Quản trị viên</span>
                }
                else if (role == "Staff")
                {
                    <span class="role-badge staff">Stylist</span>
                }
                else
                {
                    <span class="role-badge customer">Khách hàng</span>
                }
            </span>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="dash-nav">
        <!-- Home -->
        <a href="/" class="home-link">
            <span class="nav-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9,22 9,12 15,12 15,22"/>
                </svg>
            </span>
            <span>Về trang chủ</span>
        </a>

        <!-- Admin Section -->
        @if (role == "Admin")
        {
            <div class="nav-section">
                <span class="nav-section-title">Quản lý</span>
                <a href="/Admin" class="@(active == "dashboard" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="9"/>
                            <rect x="14" y="3" width="7" height="5"/>
                            <rect x="14" y="12" width="7" height="9"/>
                            <rect x="3" y="16" width="7" height="5"/>
                        </svg>
                    </span>
                    <span>Tổng quan</span>
                </a>
                <a href="/Admin/Appointments" class="@(active == "appointments" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </span>
                    <span>Lịch hẹn</span>
                    @if (pending > 0)
                    {
                        <span class="badge-notify">@pending</span>
                    }
                </a>
                <a href="/Admin/Services" class="@(active == "services" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    </span>
                    <span>Dịch vụ</span>
                </a>
                <a href="/Admin/Staff" class="@(active == "staff" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                            <path d="M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                    </span>
                    <span>Nhân viên</span>
                </a>
                <a href="/Admin/Payments" class="@(active == "payments" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                            <line x1="1" y1="10" x2="23" y2="10"/>
                        </svg>
                    </span>
                    <span>Thanh toán</span>
                </a>
                <a href="/Admin/Reports" class="@(active == "reports" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="20" x2="18" y2="10"/>
                            <line x1="12" y1="20" x2="12" y2="4"/>
                            <line x1="6" y1="20" x2="6" y2="14"/>
                        </svg>
                    </span>
                    <span>Báo cáo</span>
                </a>
            </div>
        }

        <!-- Staff Section -->
        @if (role == "Staff")
        {
            <div class="nav-section">
                <span class="nav-section-title">Stylist</span>
                <a href="/Staff" class="@(active == "dashboard" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12,6 12,12 16,14"/>
                        </svg>
                    </span>
                    <span>Ca làm việc</span>
                </a>
                <a href="/Staff/MyBookings" class="@(active == "staffhistory" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 20h9"/>
                            <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
                        </svg>
                    </span>
                    <span>Lịch sử Stylist</span>
                </a>
            </div>
        }

        <!-- Tài khoản -->
        <div class="nav-section">
            <span class="nav-section-title">Tài khoản</span>
            @if (role != "Staff")
            {
                <a href="/Booking/MyBookings" class="@(active == "mybookings" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                            <rect x="8" y="2" width="8" height="4" rx="1"/>
                        </svg>
                    </span>
                    <span>Lịch của tôi</span>
                </a>
            }
            @if (role == "Staff")
            {
                <a href="/Staff/Profile" class="@(active == "profile" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </span>
                    <span>Hồ sơ stylist</span>
                </a>
            }
            else if (!string.IsNullOrEmpty(Context.Session.GetString("AccessToken")))
            {
                <a href="/Account/Profile" class="@(active == "profile" ? "active" : "")">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </span>
                    <span>Hồ sơ</span>
                </a>
            }
        </div>

        <!-- Booking (cho tất cả mọi người) -->
        <div class="nav-section">
            <span class="nav-section-title">Đặt lịch</span>
            <a href="/Booking" class="@(active == "booking" ? "active" : "")">
                <span class="nav-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14,2 14,8 20,8"/>
                        <line x1="12" y1="18" x2="12" y2="12"/>
                        <line x1="9" y1="15" x2="15" y2="15"/>
                    </svg>
                </span>
                <span>Đặt lịch mới</span>
            </a>
        </div>
    </nav>

    <!-- Footer -->
    <div class="dash-sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-logout">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                    <polyline points="16,17 21,12 16,7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span>Đăng xuất</span>
            </button>
        </form>
    </div>
</aside>
