@using HairSalonVN.Web.Models.Booking
@model StaffDashboardViewModel
@{
    ViewData["Title"] = "Ca làm việc";
    ViewBag.DashboardRole = "Staff";
    ViewBag.ActiveMenu = "dashboard";

    var today = DateTime.Now;
    var greeting = today.Hour < 12 ? "Chào buổi sáng" : today.Hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";
}
<div class="luxe-topbar">
    <div class="luxe-topbar-left">
        <h1>@greeting, @Model.UserName</h1>
        <p class="luxe-date">
            @today.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"))
        </p>
    </div>
    <div class="luxe-topbar-right">
        <span class="luxe-role-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            Stylist
        </span>
    </div>
</div>

<div class="luxe-content">
    <div class="luxe-stats">
        <div class="stat-card stat-card-primary">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.TotalToday</span>
                <span class="stat-text">Lịch hẹn hôm nay</span>
            </div>
        </div>
        <div class="stat-card stat-card-warning">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12,6 12,12 16,14"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.PendingCount</span>
                <span class="stat-text">Chờ phục vụ</span>
            </div>
        </div>
        <div class="stat-card stat-card-success">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22,4 12,14.01 9,11.01"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.CompletedToday</span>
                <span class="stat-text">Đã hoàn thành</span>
            </div>
        </div>
        <div class="stat-card stat-card-gold">
            <div class="stat-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23,6 13.5,15.5 8.5,10.5 1,18"/>
                    <polyline points="17,6 23,6 23,12"/>
                </svg>
            </div>
            <div class="stat-card-body">
                <span class="stat-number">@Model.UpcomingAppointments.Count</span>
                <span class="stat-text">Lịch sắp tới</span>
            </div>
        </div>
    </div>

    <div class="luxe-panel">
        <div class="luxe-panel-head">
            <h2>Lịch hẹn hôm nay</h2>
            @if (Model.TodayAppointments.Any())
            {
                <span class="luxe-badge pending">@Model.TodayAppointments.Count lịch</span>
            }
        </div>
        <div class="luxe-panel-body">
            @if (!Model.TodayAppointments.Any())
            {
                <div class="luxe-empty">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                        <polyline points="22,4 12,14.01 9,11.01"/>
                    </svg>
                    <p>Không có lịch hẹn nào hôm nay</p>
                    <small>Nghỉ ngơi và chuẩn bị cho ngày mai nhé!</small>
                </div>
            }
            else
            {
                <div class="luxe-appt-cards">
                    @foreach (var appt in Model.TodayAppointments)
                    {
                        <div class="luxe-appt-card">
                            <div class="luxe-appt-info">
                                <div class="luxe-avatar" style="width:44px;height:44px;font-size:1rem;">
                                    @(string.IsNullOrEmpty(appt.CustomerName) ? '?' : appt.CustomerName[0])
                                </div>
                                <div class="luxe-appt-customer">
                                    <div class="name">
                                        @appt.CustomerName
                                        <span class="luxe-badge @appt.StatusClass" style="margin-left:8px;vertical-align:middle;">
                                            @appt.Status
                                        </span>
                                    </div>
                                    <div class="service">@appt.ServiceName</div>
                                    <div class="hour">@appt.AppointmentDate.ToString("HH:mm") · @appt.DurationMinutes phút</div>
                                </div>
                            </div>
                            <div class="luxe-actions" style="flex-shrink:0;">
                                @if (appt.Status == "Pending" || appt.Status == "Confirmed")
                                {
                                    <form asp-controller="Staff" asp-action="UpdateStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="luxe-btn-sm complete">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <polyline points="20,6 9,17 4,12"/>
                                            </svg>
                                            Hoàn thành
                                        </button>
                                    </form>
                                }
                                @if (appt.Status == "Pending")
                                {
                                    <form asp-controller="Staff" asp-action="UpdateStatus" method="post" class="cancel-form" data-appt-id="@appt.Id">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@appt.Id" />
                                        <input type="hidden" name="status" value="Cancelled" />
                                        <button type="submit" class="luxe-btn-sm cancel">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <line x1="18" y1="6" x2="6" y2="18"/>
                                                <line x1="6" y1="6" x2="18" y2="18"/>
                                            </svg>
                                            Hủy
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.UpcomingAppointments.Any())
    {
        <div class="luxe-panel">
            <div class="luxe-panel-head">
                <h2>Lịch hẹn sắp tới</h2>
                <span class="luxe-badge pending">@Model.UpcomingAppointments.Count lịch</span>
            </div>
            <div class="luxe-panel-body">
                <div class="luxe-table-wrap">
                    <table class="luxe-table">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Khách hàng</th>
                                <th>Dịch vụ</th>
                                <th>Thời gian</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in Model.UpcomingAppointments.Take(10))
                            {
                                <tr>
                                    <td>
                                        <div class="luxe-date-cell">
                                            <span class="date">@appt.AppointmentDate.ToString("dd/MM")</span>
                                            <span class="time" style="font-size:.78rem;">@appt.AppointmentDate.ToString("yyyy")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="luxe-person">
                                            <div class="luxe-avatar" style="width:34px;height:34px;font-size:.8rem;">
                                                @(string.IsNullOrEmpty(appt.CustomerName) ? '?' : appt.CustomerName[0])
                                            </div>
                                            <div>
                                                <div class="luxe-person-name">@appt.CustomerName</div>
                                                <div class="luxe-person-sub">@appt.CustomerPhone</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="luxe-person-name">@appt.ServiceName</span></td>
                                    <td>
                                        <div class="luxe-date-cell">
                                            <span class="time">@appt.AppointmentDate.ToString("HH:mm")</span>
                                            <span class="date" style="font-size:.75rem;">@appt.AppointmentDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>
                                    <td><span class="luxe-badge @appt.StatusClass">@appt.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<script>
document.querySelectorAll('.cancel-form').forEach(form => {
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        showConfirmModal('Bạn có chắc muốn hủy lịch hẹn này?', async () => {
            const formData = new FormData(this);
            try {
                const response = await fetch(this.action, {
                    method: 'POST',
                    body: formData
                });
                if (response.ok) {
                    showToast('Đã hủy lịch hẹn!', 'success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast('Không thể hủy lịch hẹn. Vui lòng thử lại.', 'error');
                }
            } catch {
                showToast('Không thể kết nối đến máy chủ.', 'error');
            }
        });
    });
});
</script>
